# ── Monaco Estate environment ────────────────────────────────────────
# Copy to `.env` for local development. On Dokploy, add these under the
# application's Environment tab (the .env file itself is not committed).

# ── MongoDB — live city chat + cloud saves (/api/chat, /api/save) ────
# Leave empty to run in local-only mode (game still fully works).
#   Format: mongodb://USER:PASSWORD@HOST:PORT
MONGODB_URI=mongodb://user:password@host:27017
MONGODB_DB=monaco-estate

# ── Wallet / chain (client-side) ─────────────────────────────────────
# WalletConnect Cloud project id used by RainbowKit (https://cloud.walletconnect.com).
# The bundled demo id works for testing; create your own before going live.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=942be6e52002f232490df2cd9e69315d

# 'baseSepolia' (testnet, default) or 'base' (mainnet)
NEXT_PUBLIC_CHAIN=baseSepolia

# $MRT token. On Base mainnet this is the canonical token below; on testnet
# use the address printed by `npm run chain:deploy:testnet`.
NEXT_PUBLIC_MRT_TOKEN_ADDRESS=0xb200000000000000000000d8b21449ecf586c801

# MonacoEstate game contract — printed by `npm run chain:deploy:testnet`.
# Empty = game runs in pure simulation mode.
NEXT_PUBLIC_ESTATE_ADDRESS=

# ── Contract deployment (server-side only, NEVER ship to the client) ──
# Private key of the deployer wallet. Fund it with Base Sepolia ETH first:
# https://docs.base.org/tools/network-faucets  — then run:
#   npm run chain:deploy:testnet
DEPLOYER_PRIVATE_KEY=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
